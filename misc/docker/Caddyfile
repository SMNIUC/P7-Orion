# Ecoute HTTP simple sur :80. L'adresse ":80" (et non "*") desactive l'HTTPS
# automatique de Caddy : pas de redirection 80->443 ni de certificat auto-signe.
# La terminaison TLS est deleguee a un reverse-proxy / ingress en amont.
:80 {
	root * /app/front
	encode gzip
	try_files {path} /index.html
	file_server
}
